{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "100%",
  "globalPassThroughEnv": ["DEBUG"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "pact-consumer": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "pact-provider": {
      "dependsOn": ["pact-consumer", "^build"],
      "cache": false
    }
  }
}
