{
  "name": "@photox/user-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pact-consumer": "vitest run --config vitest.consumer.config.ts",
    "pact-provider": "vitest run --config vitest.provider.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/typeorm": "^10.0.0",
    "@photox/shared-config": "workspace:*",
    "@photox/shared-types": "workspace:*",
    "@nestjs/jwt": "^10.0.0",
    "@photox/shared-auth": "workspace:*",
    "argon2": "^0.41.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "typeorm": "^0.3.20",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@swc/core": "^1.15.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.0",
    "testcontainers": "^10.0.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.1.0",
    "@pact-foundation/pact": "^13.0.0"
  }
}
