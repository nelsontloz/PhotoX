    "pact-provider": "vitest run --config vitest.provider.config.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^8.0.0",
    "@photox/shared-config": "workspace:*",
    "@photox/shared-types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "exifreader": "^4.41.0",
    "form-data": "^4.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@pact-foundation/pact": "^13.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "testcontainers": "^10.0.0",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.1.0"
