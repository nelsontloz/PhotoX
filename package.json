{
  "name": "photox",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "pact-consumer": "turbo run pact-consumer",
    "pact-provider": "turbo run pact-provider",
    "pact-coverage": "tsx scripts/pact-coverage.ts",
    "verify": "rm -rf pacts && pnpm run lint && pnpm run pact-consumer && pnpm run pact-provider && pnpm run pact-coverage && turbo run test --force && pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.22.4",
    "turbo": "^2.3.0"
  },
  "dependencies": {
    "pgvector": "^0.2.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "^5.4.2"
    }
  }
}
